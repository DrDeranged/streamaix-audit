# ═══════════════════════════════════════════════════════════════════════
# StreamAiX - Base Network Configuration
# ═══════════════════════════════════════════════════════════════════════

# Database Configuration (Provided by Replit)
DATABASE_URL=postgresql://username:password@hostname:port/database
PGDATABASE=your_database_name
PGHOST=your_host
PGPASSWORD=your_password
PGPORT=5432
PGUSER=your_username

# Application Configuration
NODE_ENV=development
PORT=5000

# ═══════════════════════════════════════════════════════════════════════
# BASE NETWORK CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════

# RPC URLs
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# BaseScan API Key (for contract verification)
# Get yours at: https://basescan.org/myapikey
BASESCAN_API_KEY=YourBaseScanApiKey

# ═══════════════════════════════════════════════════════════════════════
# SMART CONTRACT ADDRESSES (Update after deployment)
# ═══════════════════════════════════════════════════════════════════════

VITE_BASE_STREAM_TOKEN=0xYourStreamTokenContractAddress
VITE_BASE_SUMMARY_NFT=0xYourSummaryNFTContractAddress
VITE_BASE_STAKING=0xYourStakingContractAddress
VITE_BASE_BOUNTY_BOARD=0xYourBountyBoardContractAddress

# ═══════════════════════════════════════════════════════════════════════
# BLOCKCHAIN WALLET CONFIGURATION (IMPORTANT: KEEP PRIVATE!)
# ═══════════════════════════════════════════════════════════════════════

# Deployer/Owner Private Key (for deploying and managing contracts)
# NEVER commit this to git! This account will:
# - Deploy all smart contracts
# - Own the NFT contract (can mint NFTs)
# - Own the Token contract (can mint tokens)
PRIVATE_KEY=0xYourPrivateKeyHere

# Platform NFT Minter (backend service account for minting NFTs to users)
# This can be the same as PRIVATE_KEY or a dedicated service account
NFT_OWNER_PRIVATE_KEY=0xYourNFTOwnerPrivateKeyHere

# ═══════════════════════════════════════════════════════════════════════
# DEPLOYMENT CHECKLIST FOR BASE NETWORK
# ═══════════════════════════════════════════════════════════════════════
#
# STEP 1: Deploy Smart Contracts to Base Mainnet
#   ✓ Deploy STREAM ERC-20 Token → Update VITE_BASE_STREAM_TOKEN
#   ✓ Deploy SummaryNFT Contract → Update VITE_BASE_SUMMARY_NFT
#   ✓ Deploy Staking Contract → Update VITE_BASE_STAKING
#   ✓ Deploy BountyBoard Contract → Update VITE_BASE_BOUNTY_BOARD
#   ✓ Verify all contracts on BaseScan.org
#
# STEP 2: Database Migration
#   Run: npm run db:push
#   (Select "create column" when prompted about avatar_content_interactions)
#
# STEP 3: Test on Base Network
#   ✓ Connect wallet (MetaMask/Coinbase Wallet)
#   ✓ App will auto-detect and prompt to switch to Base
#   ✓ Create test bounty with real $STREAM tokens
#   ✓ Verify transaction on BaseScan
#
# STEP 4: Production Launch
#   ✓ Update environment variables with real contract addresses
#   ✓ Deploy to Replit (already configured for deployment)
#   ✓ Monitor BaseScan for contract activity
#
# ═══════════════════════════════════════════════════════════════════════
# ═══════════════════════════════════════════════════════════════════════
# PHASE FLAGS (added in recent hardening phases)
# ═══════════════════════════════════════════════════════════════════════

# Claude API key from console.anthropic.com
ANTHROPIC_API_KEY=

# Below this confidence, markets escalate to admin review instead of auto-resolving
RESOLUTION_CONFIDENCE_THRESHOLD=0.85

# Risk engine caps
AGENT_MAX_STAKE=500
AGENT_MAX_EXPOSURE=2000
AGENT_DRAWDOWN_LIMIT=1500
GLOBAL_HOURLY_SPEND_LIMIT=20000

# KILL SWITCH — leave false; all contract writes disabled
ONCHAIN_WRITES_ENABLED=false

# KILL SWITCH — leave false; points-to-token bridge dormant, enabling is a legal/business decision
BRIDGE_ENABLED=false

# LEAVE EMPTY until contracts deploy with a limited MINTER_ROLE; never put the admin key here
SERVICE_SIGNER_PRIVATE_KEY=
