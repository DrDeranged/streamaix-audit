modules = ["web", "postgresql-16", "nodejs-22"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["yt-dlp", "ffmpeg"]

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 34233
externalPort = 5000

[[ports]]
localPort = 34297
externalPort = 3003

[[ports]]
localPort = 36703
externalPort = 3001

[[ports]]
localPort = 37543
externalPort = 5173

[[ports]]
localPort = 38077
externalPort = 3002

[[ports]]
localPort = 39129
externalPort = 9000

[[ports]]
localPort = 40293
externalPort = 8000

[[ports]]
localPort = 40297
externalPort = 4200

[[ports]]
localPort = 42299
externalPort = 3000

[[ports]]
localPort = 42591
externalPort = 8080

[[ports]]
localPort = 42735
externalPort = 8081

[[ports]]
localPort = 43929
externalPort = 8008

[[ports]]
localPort = 43985
externalPort = 6800

[[ports]]
localPort = 44833
externalPort = 6000

[[ports]]
localPort = 45187
externalPort = 8099

[env]
PORT = "5000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[agent]
integrations = ["javascript_database==1.0.0", "javascript_websocket==1.0.0", "javascript_log_in_with_replit==1.0.0"]
